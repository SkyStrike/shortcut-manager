<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ShortcutManager.InputDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Input"
    PrimaryButtonText="OK"
    SecondaryButtonText="Cancel"
    DefaultButton="Primary">

    <StackPanel Spacing="10" Margin="0,10,0,0" Width="300">
        <TextBlock x:Name="MessageTextBlock" Text="Enter name:" TextWrapping="Wrap"/>
        <TextBox x:Name="InputTextBox" PlaceholderText="Name..."/>
    </StackPanel>
</ContentDialog>
