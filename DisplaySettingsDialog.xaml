<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ShortcutManager.DisplaySettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Display Preferences"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    DefaultButton="Primary">

    <Grid>
        <StackPanel Spacing="15" Margin="0,10,0,0" Width="400">
            <StackPanel Spacing="5">
                <TextBlock Text="Search Box Font Size" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <NumberBox x:Name="SearchBoxFontSizeBox" 
                           Minimum="8" Maximum="72" 
                           SmallChange="1" LargeChange="4"
                           SpinButtonPlacementMode="Inline"
                           HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Group Header Font Size" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <NumberBox x:Name="GroupNameFontSizeBox" 
                           Minimum="8" Maximum="72" 
                           SmallChange="1" LargeChange="4"
                           SpinButtonPlacementMode="Inline"
                           HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="App Width (Logical)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <NumberBox x:Name="AppWidthBox" 
                           Minimum="400" Maximum="3840" 
                           SmallChange="10" LargeChange="100"
                           SpinButtonPlacementMode="Inline"
                           HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Min Height Multiplier (0.1 - 1.0)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Slider x:Name="MinHeightSlider" 
                        Minimum="0.1" Maximum="1.0" 
                        StepFrequency="0.05"
                        TickFrequency="0.1"
                        TickPlacement="Outside"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>

            <StackPanel Spacing="5">
                <TextBlock Text="Top Margin Multiplier (0.0 - 0.9)" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <Slider x:Name="TopMarginSlider" 
                        Minimum="0.0" Maximum="0.9" 
                        StepFrequency="0.05"
                        TickFrequency="0.1"
                        TickPlacement="Outside"
                        HorizontalAlignment="Stretch"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</ContentDialog>
