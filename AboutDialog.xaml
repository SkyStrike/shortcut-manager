<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ShortcutManager.AboutDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="About Shortcut Manager"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <Grid>
        <StackPanel Spacing="15" Margin="0,10,0,0" Width="400">
            <TextBlock Text="A simple Shortcut Manager to organize and launch your favorite applications." 
                       TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Top">
                <TextBlock Text="Version:" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Top"/>
                <TextBox x:Name="VersionTextBox" 
                         IsReadOnly="True" 
                         BorderThickness="0" 
                         Background="Transparent"
                         Padding="0"
                         VerticalAlignment="Top"
                         TextWrapping="Wrap"
                         MaxWidth="330"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                <TextBlock Text="GitHub Repo:" Style="{StaticResource BodyStrongTextBlockStyle}" VerticalAlignment="Center"/>
                <HyperlinkButton Content="SkyStrike/shortcut-manager" 
                                 Click="GitHubButton_Click"
                                 Padding="0"
                                 VerticalAlignment="Center"
                                 HorizontalAlignment="Left"/>
            </StackPanel>

            <Button x:Name="UpdateCheckButton" 
                    HorizontalAlignment="Stretch" 
                    Margin="0,10,0,0"
                    Click="UpdateCheckButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE777;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock x:Name="UpdateCheckText" Text="Check for Updates"/>
                </StackPanel>
            </Button>
            
            <InfoBar x:Name="UpdateInfoBar" 
                     IsOpen="False" 
                     IsIconVisible="True" 
                     Margin="0,5,0,0">
                <InfoBar.ActionButton>
                    <Button Content="View Release" Click="ViewRelease_Click" />
                </InfoBar.ActionButton>
            </InfoBar>
        </StackPanel>
    </Grid>
</ContentDialog>
