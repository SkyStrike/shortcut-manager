<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="ShortcutManager.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:ShortcutManager"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="using:Microsoft.UI.Xaml.Controls"
    xmlns:tb="using:H.NotifyIcon"
    mc:Ignorable="d"
    Title="TestApp1">

    <Window.SystemBackdrop>
        <DesktopAcrylicBackdrop />
    </Window.SystemBackdrop>

    <Grid Background="Transparent">
        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="Escape" Invoked="OnEscPressed"/>
        </Grid.KeyboardAccelerators>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.Resources>
            <XamlUICommand x:Key="ToggleSidebarCommand" ExecuteRequested="ToggleSidebarCommand_ExecuteRequested" />
        </Grid.Resources>

        <tb:TaskbarIcon
            x:Name="MyTrayIcon"
            ToolTipText="Shortcut Manager"
            IconSource="star.ico"
            LeftClickCommand="{StaticResource ToggleSidebarCommand}"
            NoLeftClickDelay="True"
            >
        </tb:TaskbarIcon>

        <AutoSuggestBox x:Name="SidebarSearchBox"
                    Grid.Row="0"
                    PlaceholderText="Search shortcuts..."
                    QueryIcon="Find"
                    Margin="10"
                    TextChanged="SidebarSearchBox_TextChanged"
                    QuerySubmitted="SidebarSearchBox_QuerySubmitted"
                    Background="{ThemeResource SystemControlAcrylicElementBrush}"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="Transparent">
            <ItemsControl x:Name="GroupsList" Background="Transparent">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Header="{Binding GroupName}" 
                          IsExpanded="{Binding IsExpanded, Mode=TwoWay}"
                          Expanding="Expander_Expanding"
                          Collapsed="Expander_Collapsed"
                          HorizontalAlignment="Stretch" 
                          Margin="5,2"
                          Background="{ThemeResource SystemControlAcrylicElementBrush}">

                            <ItemsRepeater ItemsSource="{Binding Shortcuts}">
                                <ItemsRepeater.Layout>
                                    <UniformGridLayout Orientation="Horizontal" 
                                                       MinItemWidth="110" 
                                                       MinColumnSpacing="5" 
                                                       MinRowSpacing="5" />
                                </ItemsRepeater.Layout>

                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate>
                                        <Button Click="OnShortcutClick" 
                    Padding="5"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    VerticalAlignment="Top"
                    ToolTipService.ToolTip="{Binding Path}">

                                            <StackPanel Width="100" Spacing="5">
                                                <Image Source="{Binding Icon}" 
                           Width="32" 
                           Height="32" 
                           HorizontalAlignment="Center"
                           Stretch="Uniform"/>

                                                <TextBlock Text="{Binding Name}" 
                               FontSize="11" 
                               HorizontalAlignment="Center" 
                               TextAlignment="Center" 
                               TextWrapping="Wrap" 
                               TextTrimming="None"/>
                                            </StackPanel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
