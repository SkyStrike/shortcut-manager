<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ShortcutManager.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <StackPanel Spacing="15" Margin="0,10,0,0" Width="400">
        <CheckBox x:Name="StartupCheckBox" Content="Run at Windows Startup" Checked="StartupCheckBox_Checked" Unchecked="StartupCheckBox_Unchecked"/>
        
        <Button HorizontalAlignment="Stretch" Click="OpenDirButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xED25;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Open Application Directory"/>
            </StackPanel>
        </Button>

        <Button HorizontalAlignment="Stretch" Click="OpenStartupDirButton_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Open Startup Directory"/>
            </StackPanel>
        </Button>

        <Button HorizontalAlignment="Stretch" Click="RegenerateAllIcons_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Regenerate All Icons"/>
            </StackPanel>
        </Button>

        <Button HorizontalAlignment="Stretch" Click="CleanUpIcons_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Clean Up Unused Icons"/>
            </StackPanel>
        </Button>

        <Button HorizontalAlignment="Stretch" Click="RemoveInvalidShortcuts_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE9CE;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Remove Invalid Shortcuts"/>
            </StackPanel>
        </Button>

        <Button HorizontalAlignment="Stretch" Click="CreateBackup_Click">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                <TextBlock Text="Create Backup"/>
            </StackPanel>
        </Button>

        <StackPanel Spacing="2">
            <TextBlock Text="Version Info" Style="{StaticResource BodyStrongTextBlockStyle}"/>
            <TextBox x:Name="VersionTextBox" 
                     IsReadOnly="True" 
                     BorderThickness="0" 
                     Background="Transparent"
                     Padding="0"
                     TextWrapping="Wrap"
                     Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>
    </StackPanel>
</ContentDialog>
