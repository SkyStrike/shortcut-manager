<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="ShortcutManager.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Settings"
    PrimaryButtonText="Close"
    DefaultButton="Primary">

    <Grid>
        <StackPanel Spacing="15" Margin="0,10,0,0" Width="400">
            <CheckBox x:Name="StartupCheckBox" Content="Run at Windows Startup" Checked="StartupCheckBox_Checked" Unchecked="StartupCheckBox_Unchecked"/>
            <CheckBox x:Name="StartHiddenCheckBox" Content="Start Hidden (System Tray only)" Checked="StartHiddenCheckBox_Checked" Unchecked="StartHiddenCheckBox_Unchecked" Margin="25,-10,0,0" IsEnabled="{Binding ElementName=StartupCheckBox, Path=IsChecked}"/>
            
            <Button HorizontalAlignment="Stretch" Click="OpenDirButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xED25;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Open Application Directory"/>
                </StackPanel>
            </Button>

            <Button HorizontalAlignment="Stretch" Click="OpenStartupDirButton_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE8B7;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Open Startup Directory"/>
                </StackPanel>
            </Button>

            <Button HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Regenerate All Icons"/>
                </StackPanel>
                <Button.Flyout>
                    <Flyout x:Name="RegenerateFlyout">
                        <StackPanel Spacing="15" Width="380">
                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="Orange" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Regenerate Icons?" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="This will refresh icons for all shortcuts. Any manually customized icons will be lost. Do you want to proceed?" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Click="Cancel_Click" />
                                <Button Content="Regenerate" Click="RegenerateAllIcons_ConfirmClick" Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE74D;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Clean Up Unused Icons"/>
                </StackPanel>
                <Button.Flyout>
                    <Flyout x:Name="CleanUpIconsFlyout">
                        <StackPanel Spacing="15" Width="380">
                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="Orange" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Clean Up Icons?" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="This will delete all cached icons that are not currently used by any of your shortcuts. Do you want to proceed?" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Click="Cancel_Click" />
                                <Button Content="Clean Up" Click="CleanUpIcons_ConfirmClick" Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE9CE;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Remove Invalid Shortcuts"/>
                </StackPanel>
                <Button.Flyout>
                    <Flyout x:Name="RemoveInvalidFlyout">
                        <StackPanel Spacing="15" Width="380">
                            <Grid ColumnDefinitions="36,*" ColumnSpacing="12">
                                <FontIcon Grid.Column="0" Glyph="&#xE7BA;" FontFamily="Segoe Fluent Icons" FontSize="24" Foreground="Orange" VerticalAlignment="Top"/>
                                <StackPanel Grid.Column="1" Spacing="2">
                                    <TextBlock Text="Remove Invalid Shortcuts?" Style="{StaticResource SubtitleTextBlockStyle}" TextWrapping="Wrap"/>
                                    <TextBlock Text="This will scan all groups and remove shortcuts that point to files or directories that no longer exist. Do you want to proceed?" TextWrapping="Wrap" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                </StackPanel>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                                <Button Content="Cancel" Click="Cancel_Click" />
                                <Button Content="Remove Invalid" Click="RemoveInvalidShortcuts_ConfirmClick" Style="{StaticResource AccentButtonStyle}" />
                            </StackPanel>
                        </StackPanel>
                    </Flyout>
                </Button.Flyout>
            </Button>

            <Button HorizontalAlignment="Stretch" Click="CreateBackup_Click">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE7AD;" FontFamily="Segoe Fluent Icons" />
                    <TextBlock Text="Create Backup"/>
                </StackPanel>
            </Button>

            <StackPanel Spacing="2">
                <TextBlock Text="Version Info" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                <TextBox x:Name="VersionTextBox" 
                         IsReadOnly="True" 
                         BorderThickness="0" 
                         Background="Transparent"
                         Padding="0"
                         TextWrapping="Wrap"
                         Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </StackPanel>

        <InfoBar x:Name="StatusInfoBar"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,-10"
                 IsOpen="False"
                 IsIconVisible="True" />
    </Grid>
</ContentDialog>
